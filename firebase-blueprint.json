{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" },
        "completedLessons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email"]
    },
    "Roadmap": {
      "title": "Learning Roadmap",
      "description": "Generated personalized roadmap",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "level": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PracticeQuestion": {
      "title": "Practice Question",
      "description": "Coding or MCQ practice question",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "topic": { "type": "string" },
        "type": { "type": "string", "enum": ["MCQ", "Coding"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "solution": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "User profiles and progress"
    },
    "roadmaps": {
      "schema": "Roadmap",
      "description": "Personalized roadmaps"
    },
    "practice": {
      "schema": "PracticeQuestion",
      "description": "Curated collection of practice questions"
    }
  }
}
